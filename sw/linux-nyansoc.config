# Linux kernel configuration for NyanSoC (RV32IMA, Sv32 MMU)
#
# Key constraints:
#   - RV32IMA only (no F/D/C extensions)
#   - Single hart, no SMP
#   - 32 MB SDRAM at 0x8000_0000
#   - Console via SBI (hvc0) — NyanSoC UART is not 8250-compatible
#   - OpenSBI fw_jump passes DTB in a1
#   - Kernel loads at 0x8020_0000 (after OpenSBI at 0x8000_0000)
#   - Initramfs packed into kernel image

CONFIG_RISCV=y
CONFIG_32BIT=y
CONFIG_ARCH_RV32I=y
CONFIG_RISCV_ISA_RV32I=y
CONFIG_RISCV_ISA_M=y
CONFIG_RISCV_ISA_A=y
# CONFIG_RISCV_ISA_C is not set
# CONFIG_RISCV_ISA_F is not set
# CONFIG_RISCV_ISA_D is not set
CONFIG_MMU=y
CONFIG_PAGE_OFFSET=0x80000000

# ── SMP: single hart only ──────────────────────────────────────────────────────
# CONFIG_SMP is not set
CONFIG_NR_CPUS=1

# ── Memory ────────────────────────────────────────────────────────────────────
CONFIG_PHYSICAL_START=0x80200000
CONFIG_PHYSICAL_ALIGN=0x200000

# ── Console via SBI (hvc0) ────────────────────────────────────────────────────
CONFIG_HVC_DRIVER=y
CONFIG_HVC_RISCV_SBI=y
CONFIG_SERIAL_EARLYCON_RISCV_SBI=y
CONFIG_CMDLINE="console=hvc0 earlycon=sbi root=/dev/ram rw"
CONFIG_CMDLINE_BOOL=y
CONFIG_CMDLINE_OVERRIDE=n

# ── No 8250/16550 UART driver (NyanSoC UART is custom) ────────────────────────
# CONFIG_SERIAL_8250 is not set

# ── Initramfs ─────────────────────────────────────────────────────────────────
CONFIG_BLK_DEV_INITRD=y
CONFIG_INITRAMFS_SOURCE=""
CONFIG_RD_GZIP=y

# ── Minimal driver set ────────────────────────────────────────────────────────
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
# CONFIG_SOUND is not set
# CONFIG_USB_SUPPORT is not set
# CONFIG_PCI is not set
# CONFIG_PCCARD is not set
# CONFIG_NET is not set
# CONFIG_WIRELESS is not set
# CONFIG_WLAN is not set

# ── Filesystems ───────────────────────────────────────────────────────────────
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_EXT4_FS=y
# CONFIG_EXT4_USE_FOR_EXT2 is not set

# ── Clocks / timers ───────────────────────────────────────────────────────────
CONFIG_RISCV_TIMER=y
CONFIG_CLINT_TIMER=y

# ── PLIC ──────────────────────────────────────────────────────────────────────
CONFIG_RISCV_INTC=y
CONFIG_SIFIVE_PLIC=y

# ── Reduce kernel size ────────────────────────────────────────────────────────
# CONFIG_MODULES is not set
# CONFIG_BLK_DEV_BSG is not set
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
# CONFIG_PROFILING is not set
# CONFIG_KPROBES is not set
# CONFIG_FTRACE is not set
# CONFIG_DEBUG_KERNEL is not set
