# Buildroot configuration for NyanSoC (Tang Nano 20K, RV32IMA Sv32)
#
# Produces:
#   output/images/vmlinux          — uncompressed kernel ELF
#   output/images/Image            — flat binary (load at 0x8020_0000)
#   output/build/linux-*/vmlinux   — with debug symbols
#
# Usage:
#   cd /Users/v/workspace/buildroot
#   make BR2_DEFCONFIG=../NyanSoC/sw/buildroot-nyansoc.config defconfig
#   make -j$(nproc)

# ── Architecture ──────────────────────────────────────────────────────────────
BR2_riscv=y
BR2_RISCV_32=y
BR2_RISCV_ISA_RV32IMA=y
BR2_RISCV_ABI_ILP32=y

# ── Toolchain: build a Linux-targeting musl toolchain ─────────────────────────
BR2_TOOLCHAIN_BUILDROOT=y
BR2_TOOLCHAIN_BUILDROOT_MUSL=y
BR2_TOOLCHAIN_BUILDROOT_WCHAR=y

# ── Linux kernel ──────────────────────────────────────────────────────────────
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_CUSTOM_VERSION=y
BR2_LINUX_KERNEL_CUSTOM_VERSION_VALUE="6.6"
BR2_LINUX_KERNEL_USE_CUSTOM_CONFIG=y
BR2_LINUX_KERNEL_CUSTOM_CONFIG_FILE="$(BR2_EXTERNAL_NYANSOC_PATH)/linux-nyansoc.config"
BR2_LINUX_KERNEL_IMAGE_TARGET_NAME="Image"
BR2_LINUX_KERNEL_NEEDS_HOST_OPENSSL=y

# ── Root filesystem: initramfs packed into the kernel ─────────────────────────
BR2_TARGET_ROOTFS_INITRAMFS=y
BR2_TARGET_ROOTFS_CPIO=y
BR2_TARGET_ROOTFS_CPIO_GZIP=y

# ── BusyBox ───────────────────────────────────────────────────────────────────
BR2_PACKAGE_BUSYBOX=y
BR2_PACKAGE_BUSYBOX_SHOW_OTHERS=y

# ── No bootloader (we use OpenSBI + uart_loader) ──────────────────────────────
BR2_TARGET_UBOOT=n

# ── System ────────────────────────────────────────────────────────────────────
BR2_SYSTEM_HOSTNAME="nyansoc"
BR2_SYSTEM_BANNER="Welcome to NyanSoC Linux"
BR2_TARGET_GENERIC_GETTY=y
BR2_TARGET_GENERIC_GETTY_PORT="hvc0"
BR2_TARGET_GENERIC_GETTY_BAUDRATE_115200=y
